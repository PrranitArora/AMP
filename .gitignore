# =============================================================================
# .gitignore — AutomotiveMediaServicePrranit (Android / Kotlin multi-module)
# =============================================================================

# ── Gradle build outputs & caches ────────────────────────────────────────────
.gradle/
**/build/
gradle-app.setting

# Keep the Gradle wrapper JAR so contributors don't need Gradle pre-installed
!gradle/wrapper/gradle-wrapper.jar

# ── Android Studio / IntelliJ IDEA ───────────────────────────────────────────
# Auto-generated module files
*.iml

# IDE caches and auto-generated library configs
.idea/caches/
.idea/libraries/

# References to .iml files — regenerated on project import
.idea/modules.xml

# Personal window layout, breakpoints, recent files (machine-specific)
.idea/workspace.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
.idea/deploymentTargetSelector.xml
.idea/deviceManager.xml
.idea/appInsightsSettings.xml

# NOTE: .idea/gradle.xml, .idea/compiler.xml, .idea/misc.xml,
#       .idea/runConfigurations.xml, and .idea/vcs.xml ARE committed
#       because they contain shareable project-level settings.

# ── Local machine configuration ───────────────────────────────────────────────
# Contains local Android SDK path — machine-specific, auto-generated by Studio
local.properties

# ── Signing secrets — NEVER commit these ──────────────────────────────────────
# Contains real keystore passwords — use keystore.properties.template instead
keystore.properties

# Binary keystore and certificate files
*.keystore
*.jks
*.p12

# ── External native build artefacts ──────────────────────────────────────────
.externalNativeBuild/
.cxx/

# ── Profiling & captures ──────────────────────────────────────────────────────
/captures/
*.hprof

# ── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ── Editor temporaries ────────────────────────────────────────────────────────
*.swp
*.swo
*~
.vscode/

# ── Test reports (regenerated; not source) ────────────────────────────────────
**/test-results/
**/reports/
